// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ChannelType {
  WHATSAPP
  INSTAGRAM
}

enum ChannelProvider {
  BAILEYS
  EVOLUTION_API
  META_CLOUD_API
  INSTAGRAM_GRAPH_API
}

enum ChannelAccountStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  SYNCING
  ERROR
}

enum ConversationType {
  DIRECT
  GROUP
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageKind {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  CONTACT
  SYSTEM
  UNKNOWN
}

enum MessageStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum QueueJobStatus {
  DRAFT
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum QueueRecipientStatus {
  PENDING
  SENDING
  SENT
  FAILED
  SKIPPED
}

model ChannelAccount {
  id                    String               @id @default(cuid())
  type                  ChannelType
  provider              ChannelProvider
  displayName           String
  externalAccountId     String?
  phoneNumber           String?
  status                ChannelAccountStatus @default(DISCONNECTED)
  providerInstanceId    String?
  providerBaseUrl       String?
  providerSecretRef     String?
  authStateLocation     String?
  lastConnectedAt       DateTime?
  lastSyncAt            DateTime?
  metadata              Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  // Instagram-specific fields (null for non-IG accounts)
  igAccessToken         String?
  igTokenExpiresAt      DateTime?
  igUserId              String?   // IG Business/Creator account ID
  igUsername            String?
  igProfilePicUrl       String?

  contacts         Contact[]
  conversations    Conversation[]
  messages         Message[]
  queueJobs        MessageQueueJob[]
  igPosts          IgPost[]
  igDms            IgDm[]
  igMonitorTargets IgMonitorTarget[]

  @@unique([provider, externalAccountId])
  @@unique([provider, providerInstanceId])
  @@index([type, status])
}

model Contact {
  id               String   @id @default(cuid())
  channelAccountId String
  externalId       String
  phoneNumber      String?
  username         String?
  displayName      String
  avatarUrl        String?
  isGroup          Boolean  @default(false)
  isBlocked        Boolean  @default(false)
  labels           String[] @default([])
  metadata         Json?
  lastSeenAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  channelAccount ChannelAccount @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)
  conversations  ConversationContact[]
  messages       Message[]
  queueRecipients MessageQueueRecipient[]

  @@unique([channelAccountId, externalId])
  @@index([channelAccountId, phoneNumber])
  @@index([displayName])
}

model Conversation {
  id               String           @id @default(cuid())
  channelAccountId String
  externalId       String
  type             ConversationType @default(DIRECT)
  title            String
  avatarUrl        String?
  unreadCount      Int              @default(0)
  isArchived       Boolean          @default(false)
  isPinned         Boolean          @default(false)
  lastMessageAt    DateTime?
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  channelAccount ChannelAccount @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)
  participants   ConversationContact[]
  messages       Message[]

  @@unique([channelAccountId, externalId])
  @@index([channelAccountId, lastMessageAt])
}

model ConversationContact {
  conversationId String
  contactId      String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([conversationId, contactId])
}

model Message {
  id               String           @id @default(cuid())
  channelAccountId String
  conversationId   String
  contactId        String?
  externalId       String
  direction        MessageDirection
  kind             MessageKind      @default(TEXT)
  status           MessageStatus    @default(PENDING)
  body             String?
  mediaUrl         String?
  mediaMimeType    String?
  quotedMessageId  String?
  sentAt           DateTime?
  deliveredAt      DateTime?
  readAt           DateTime?
  failedAt         DateTime?
  failureReason    String?
  rawPayload       Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  channelAccount ChannelAccount @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact        Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([channelAccountId, externalId])
  @@index([conversationId, sentAt])
  @@index([channelAccountId, status])
}

model MessageQueueJob {
  id                String         @id @default(cuid())
  channelAccountId  String
  title             String
  body              String
  mediaUrl          String?
  mediaMimeType     String?
  status            QueueJobStatus @default(DRAFT)
  maxRecipients     Int            @default(5)
  delaySeconds      Int            @default(45)
  jitterSeconds     Int            @default(15)
  scheduledFor      DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  pausedAt          DateTime?
  failureReason     String?
  createdByUserId   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  channelAccount ChannelAccount          @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)
  recipients     MessageQueueRecipient[]

  @@index([channelAccountId, status])
  @@index([scheduledFor])
}

model MessageQueueRecipient {
  id               String               @id @default(cuid())
  queueJobId       String
  contactId        String
  status           QueueRecipientStatus @default(PENDING)
  position         Int
  attempts         Int                  @default(0)
  nextAttemptAt    DateTime?
  sentAt           DateTime?
  failureReason    String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  queueJob MessageQueueJob @relation(fields: [queueJobId], references: [id], onDelete: Cascade)
  contact  Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([queueJobId, contactId])
  @@index([queueJobId, status, position])
  @@index([nextAttemptAt])
}

// ─── Instagram Models ─────────────────────────────────────────────────────────

enum IgMediaType {
  IMAGE
  VIDEO
  CAROUSEL_ALBUM
  REEL
  STORY
}

enum IgCommentReplyStatus {
  NONE
  PENDING
  SENT
  FAILED
}

model IgPost {
  id               String      @id @default(cuid())
  channelAccountId String
  externalId       String      // IG media ID
  mediaType        IgMediaType
  caption          String?
  permalink        String?
  thumbnailUrl     String?
  mediaUrl         String?
  likeCount        Int         @default(0)
  commentsCount    Int         @default(0)
  reach            Int?
  impressions      Int?
  saved            Int?
  isStory          Boolean     @default(false)
  rawInsights      Json?
  postedAt         DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  channelAccount ChannelAccount @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)
  comments       IgComment[]

  @@unique([channelAccountId, externalId])
  @@index([channelAccountId, postedAt])
}

model IgComment {
  id               String               @id @default(cuid())
  igPostId         String
  externalId       String
  text             String
  username         String
  userExternalId   String?
  parentCommentId  String?              // null = top-level, set = reply
  replyStatus      IgCommentReplyStatus @default(NONE)
  replyText        String?
  repliedAt        DateTime?
  hidden           Boolean              @default(false)
  timestamp        DateTime
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  igPost   IgPost     @relation(fields: [igPostId], references: [id], onDelete: Cascade)
  replies  IgComment[] @relation("CommentReplies")
  parent   IgComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])

  @@unique([igPostId, externalId])
  @@index([igPostId, timestamp])
}

model IgDm {
  id                  String   @id @default(cuid())
  channelAccountId    String
  externalId          String   // IG conversation/thread ID
  participantUsername String?
  participantIgId     String?
  messages            Json     @default("[]")
  lastMessageAt       DateTime?
  withinWindow        Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  channelAccount ChannelAccount @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)

  @@unique([channelAccountId, externalId])
  @@index([channelAccountId, lastMessageAt])
}

model IgMonitorTarget {
  id               String   @id @default(cuid())
  channelAccountId String
  username         String
  igBusinessId     String?  // resolved via Business Discovery API
  displayName      String?
  profilePicUrl    String?
  enabled          Boolean  @default(true)
  lastCheckedAt    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  channelAccount ChannelAccount  @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)
  posts          IgMonitorPost[]

  @@unique([channelAccountId, username])
  @@index([channelAccountId, enabled])
}

model IgMonitorPost {
  id               String      @id @default(cuid())
  targetId         String
  externalId       String      // IG media ID
  caption          String?
  permalink        String?
  mediaType        IgMediaType
  thumbnailUrl     String?
  mediaUrl         String?
  likeCount        Int         @default(0)
  commentsCount    Int         @default(0)
  postedAt         DateTime?
  seenAt           DateTime    @default(now())
  createdAt        DateTime    @default(now())

  target IgMonitorTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([targetId, externalId])
  @@index([targetId, postedAt])
}
